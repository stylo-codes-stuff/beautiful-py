//a little break from js syntactic hell
file_input: (commands)

commands: (point_left|point_right|mem_cell_decrement|mem_cell_increment|output|input|jump_back|jump_past)
point_right: ">"
point_left: "<"
mem_cell_increment: "+"
mem_cell_decrement: "-"
output: "."
input:","
jump_past: "["
jump_back:"]"
